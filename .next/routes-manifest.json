  "dynamicRoutes": [
    {
      "page": "/api/admin/categories/[id]",
      "regex": "^/api/admin/categories/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/admin/categories/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/products/[id]",
      "regex": "^/api/products/([^/]+?)(?:/)?$",
